# Cache-Control headers for Workers Static Assets.
#
# Terraform `cloudflare_ruleset` for the http_request_cache_settings
# phase fails with 403 on this Free-plan zone (same constraint that
# killed the www→apex redirect ruleset — see TODO.md). Shipping the
# rules in this file is the API-token-independent path. Cloudflare
# reads `_headers` from the static-assets bundle at deploy time and
# applies the matches at the edge when ASSETS.fetch() serves them.
#
# Replaces infrastructure/cloudflare/global/cache.tf (which was
# correct as written but cannot be applied). Plan:
# docs/plans/2026-05-14-render-blocking-cache-ttl.md.

# Astro content-hashes every filename in _astro/* (the manifest URL
# changes any time the contents change). Safe to mark immutable for
# a year — clients never need to revalidate. App screenshots now
# ride this rule too: src/assets/screenshots/* sources flow through
# Astro's image pipeline to /_astro/<name>.<hash>.{webp,avif}. See
# docs/plans/2026-05-14-asset-pipeline-cache-busting.md.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Stable-URL-by-convention files (browser, PWA, search-engine spec,
# plus the claude-code-authoring-formats style demo PNGs whose
# filenames encode style+type and are referenced from JS-built
# template literals — can't be hashed). Short max-age plus
# stale-while-revalidate lets in-place updates propagate within a
# day without ever paying a cold fetch on revalidate. Verify SWR is
# honored by Workers Static Assets via:
#   curl -sI https://indri.studio/favicon.ico | grep -i cache-control
# If the response strips `stale-while-revalidate`, no harm done —
# max-age alone is still in effect.
/favicon.ico
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
/favicon.svg
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
/apple-touch-icon.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
/icon-*.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
/site.webmanifest
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
/robots.txt
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
/sitemap-index.xml
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
/sitemap-*.xml
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
/img/cca-styles/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Lighthouse JSON archives are immutable once written — a tag's audit
# data never changes. Cache for a year to prevent unnecessary revalidation.
/lh/*
  Cache-Control: public, max-age=31536000, immutable
