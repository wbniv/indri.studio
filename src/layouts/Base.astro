---
import "../styles/global.css";
import RingFlare from "../components/RingFlare.astro";

interface Props {
	title: string;
	description?: string;
	/* Phosphor-neon ring bursts ambient layer. On by default for the studio
	 * front; off for per-app pages so each app's own visual identity has
	 * room. AppLayout passes `ringFlare={false}`. */
	ringFlare?: boolean;
}

const { title, description = "indri.studio — small studio, building apps people use every day.", ringFlare = true } = Astro.props;

const siteTitle = "indri";
const fullTitle = title === siteTitle ? siteTitle : `${title} · ${siteTitle}`;

const pathname = Astro.url.pathname;

const navLinkClass = (active: boolean) =>
	[
		"font-display uppercase tracking-[0.25em] text-xs transition-colors",
		active
			? "text-primary-container"
			: "text-on-surface-variant hover:text-primary-container",
	].join(" ");
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#b026ff" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap"
		/>
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
		/>
		<slot name="head" />
		<title>{fullTitle}</title>
		<script is:inline>
			// Scroll-shrink: --header-shrink ramps 0 → 1 as scrollY goes
			// 0 → half a viewport. CSS reads it to interpolate the
			// header's inner padding. rAF-batched to one update per frame.
			// Ease-out curve so the header reacts immediately to scroll
			// then settles into min, rather than feeling laggy.
			if (!matchMedia("(prefers-reduced-motion: reduce)").matches) {
				let pending = false;
				const update = () => {
					pending = false;
					const raw = Math.min(1, window.scrollY / (window.innerHeight / 2));
					const eased = 1 - (1 - raw) * (1 - raw);
					document.documentElement.style.setProperty("--header-shrink", eased.toFixed(3));
				};
				const tick = () => {
					if (pending) return;
					pending = true;
					requestAnimationFrame(update);
				};
				window.addEventListener("scroll", tick, { passive: true });
				window.addEventListener("resize", tick, { passive: true });
				update();
			}
		</script>
	</head>
	<body class="min-h-screen flex flex-col bg-surface text-on-surface font-body">
		{ringFlare && <RingFlare />}

		<header
			transition:persist
			class="header-fx sticky top-0 z-50 w-full border-b border-[rgba(26,24,21,0.4)] bg-primary-container backdrop-blur-md"
		>
			<div class="flex justify-between items-center w-full px-6 md:px-8 max-w-[var(--container-max)] mx-auto">
				<a href="/" class="flex items-center gap-3 group">
					<span class="block w-3 h-3 bg-grey-900 shrink-0"></span>
					<span class="font-display text-xl md:text-2xl font-black uppercase tracking-[0.3em] text-on-surface transition-colors">
						INDRI
					</span>
				</a>
			</div>
		</header>

		<main class="flex-1 w-full">
			<slot />
		</main>

		<footer
			transition:persist
			class="w-full border-t border-[color-mix(in_srgb,_var(--color-primary-container)_15%,_transparent)] bg-surface-container-lowest"
		>
			<div
				class="max-w-[var(--container-max)] mx-auto px-6 md:px-8 py-10 md:py-12 flex flex-col md:flex-row md:items-end md:justify-between gap-6"
			>
				<div class="flex items-center gap-3">
					<span class="block w-3 h-3 bg-primary-container shrink-0"></span>
					<span class="font-display text-base font-black uppercase tracking-[0.3em] text-on-surface">
						INDRI
					</span>
				</div>
				<div class="font-display uppercase text-[10px] tracking-[0.3em] text-on-surface-variant">
					<span class="opacity-50">© {new Date().getFullYear()}</span>
				</div>
			</div>
		</footer>
	</body>
</html>
