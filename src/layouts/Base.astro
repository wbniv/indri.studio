---
import "../styles/global.css";
import RingFlare from "../components/RingFlare.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
	title: string;
	description?: string;
	/* Phosphor-neon ring bursts ambient layer. On by default for the studio
	 * front; off for per-app pages so each app's own visual identity has
	 * room. AppLayout passes `ringFlare={false}`. */
	ringFlare?: boolean;
}

const { title, description = "indri.studio — small studio, building apps people use every day.", ringFlare = true } = Astro.props;

const siteTitle = "indri";
const fullTitle = title === siteTitle ? siteTitle : `${title} · ${siteTitle}`;

const pathname = Astro.url.pathname;

const navLinkClass = (active: boolean) =>
	[
		"font-display uppercase tracking-[0.25em] text-xs transition-colors",
		active
			? "text-primary-container"
			: "text-on-surface-variant hover:text-primary-container",
	].join(" ");
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#b026ff" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=optional"
		/>
		<!-- Material Symbols Outlined loaded non-blocking — only used on
		 ~ /404 and per-app pages. preload + onload-swap lets the request
		 ~ happen off the critical path; <noscript> fallback keeps icons
		 ~ working when JS is disabled. -->
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block"
			onload="this.onload=null; this.rel='stylesheet'"
		/>
		<noscript>
			<link
				rel="stylesheet"
				href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block"
			/>
		</noscript>
		<slot name="head" />
		<title>{fullTitle}</title>
		<ClientRouter />
		<script is:inline>
			// Post-swap scroll fix. Chrome's moveBefore() (used by Astro's
			// swap for transition:persist elements) anchors the persisted
			// footer to the bottom of the new document — so the page lands
			// at scrollY = docH - viewport regardless of where the router
			// tried to scroll. The router's own scrollTo (top:0 for
			// push/replace, history-state for traverse) runs synchronously
			// and gets overridden once the post-swap layout pass applies
			// the anchor shift. Re-assert in rAF, mirroring the router's
			// own logic, so we scroll *after* the override lands. Skip
			// hash navigation — the browser owns that case.
			document.addEventListener("astro:before-preparation", (e) => {
				const navType = e.navigationType;
				const target =
					navType === "traverse"
						? { left: history.state?.scrollX ?? 0, top: history.state?.scrollY ?? 0 }
						: { left: 0, top: 0 };
				document.addEventListener(
					"astro:after-swap",
					() => {
						if (location.hash) return;
						requestAnimationFrame(() =>
							window.scrollTo({ ...target, behavior: "instant" }),
						);
					},
					{ once: true },
				);
			});

			// Scroll-shrink: --header-shrink ramps 0 → 1 as scrollY goes
			// 0 → half a viewport. CSS (var registered via @property,
			// transitioned on `html`) interpolates the header's inner
			// padding through every value change.
			//
			// Cross-page nav uses ClientRouter, so state persists. But
			// scrollY resets to 0 on the new page mid-transition; the
			// scroll listener would fire and set --header-shrink to 0
			// BEFORE the new-page snapshot is captured, leaving the fade
			// with no size delta to animate. Gate update() during the
			// view transition so the var stays at its old (shrunk) value
			// through snapshot capture, then re-run update() on
			// astro:page-load so the CSS transition fires from old → new
			// on the now-visible new page.
			if (!matchMedia("(prefers-reduced-motion: reduce)").matches) {
				let pending = false;
				let inTransition = false;
				let firstLoad = true;
				const update = () => {
					pending = false;
					if (inTransition) return;
					const raw = Math.min(1, window.scrollY / (window.innerHeight / 2));
					const eased = 1 - (1 - raw) * (1 - raw);
					document.documentElement.style.setProperty("--header-shrink", eased.toFixed(3));
				};
				const tick = () => {
					if (pending) return;
					pending = true;
					requestAnimationFrame(update);
				};
				window.addEventListener("scroll", tick, { passive: true });
				window.addEventListener("resize", tick, { passive: true });
				document.addEventListener("astro:before-preparation", () => {
					inTransition = true;
				});
				document.addEventListener("astro:page-load", () => {
					inTransition = false;
					// First paint: the scrollY read inside update() forces a
					// sync layout right before the first frame, which Lighthouse
					// flags as forced-reflow on long pages (e.g. /colophon/).
					// If we're at the top, the CSS default for --header-shrink
					// is already 0 → no work to do. If the user landed scrolled
					// (hash anchor), defer the read to idle so it doesn't block
					// the critical path. Subsequent page-loads (post-transition)
					// keep the prompt rAF path so the cross-page header animation
					// fires without delay.
					if (firstLoad) {
						firstLoad = false;
						if (window.scrollY === 0) return;
						const run = () => requestAnimationFrame(update);
						if ("requestIdleCallback" in window) {
							requestIdleCallback(run, { timeout: 250 });
						} else {
							setTimeout(run, 0);
						}
						return;
					}
					requestAnimationFrame(update);
				});
			}
		</script>
	</head>
	<body class="min-h-screen flex flex-col text-on-surface font-body">
		{ringFlare && <RingFlare />}

		<header
			transition:persist
			class="header-fx sticky top-0 z-50 w-full border-b border-[rgba(26,24,21,0.4)] bg-primary-container backdrop-blur-md"
		>
			<div class="flex justify-between items-center w-full px-6 md:px-8 max-w-[var(--container-max)] mx-auto">
				<a href="/" class="flex items-center gap-3 group">
					<span class="block w-3 h-3 bg-grey-900 shrink-0"></span>
					<span class="font-display text-xl md:text-2xl font-black uppercase tracking-[0.3em] text-on-surface transition-colors">
						INDRI
					</span>
				</a>
			</div>
		</header>

		<main class="flex-1 w-full flex flex-col">
			<slot />
		</main>

		<footer
			transition:persist
			class="w-full border-t border-[color-mix(in_srgb,_var(--color-primary-container)_15%,_transparent)] bg-surface-container-lowest"
		>
			<div
				class="max-w-[var(--container-max)] mx-auto px-6 md:px-8 py-10 md:py-12 flex flex-row items-end justify-between gap-6"
			>
				<div class="flex items-center gap-3">
					<span class="block w-3 h-3 bg-primary-container shrink-0"></span>
					<span class="font-display text-base font-black uppercase tracking-[0.3em] text-on-surface">
						INDRI
					</span>
				</div>
				<div class="font-display uppercase text-[10px] tracking-[0.3em] text-on-surface-variant flex items-center gap-2">
					<a
						href="mailto:hello@indri.studio"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="Email Indri"
						class="opacity-70 hover:opacity-100 hover:text-primary-container transition-all inline-flex items-center"
					>
						<span class="material-symbols-outlined" aria-hidden="true" style="font-size: 14px;">mail</span>
					</a>
					<span aria-hidden="true">·</span>
					<a
						href="/colophon"
						class={`opacity-70 hover:opacity-100 hover:text-primary-container transition-all ${pathname === "/colophon" ? "text-primary-container opacity-100" : ""}`}
					>
						© {new Date().getFullYear()}
					</a>
				</div>
			</div>
		</footer>
	</body>
</html>
