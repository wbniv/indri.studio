---
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "indri.studio — small studio, building apps people use every day." } = Astro.props;

const siteTitle = "indri";
const fullTitle = title === siteTitle ? siteTitle : `${title} · ${siteTitle}`;

const pathname = Astro.url.pathname;

const navLinkClass = (active: boolean) =>
	[
		"font-display uppercase tracking-[0.25em] text-xs transition-colors",
		active
			? "text-primary-container"
			: "text-on-surface-variant hover:text-primary-container",
	].join(" ");
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#b026ff" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap"
		/>
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
		/>
		<title>{fullTitle}</title>
	</head>
	<body class="min-h-screen flex flex-col bg-surface text-on-surface font-body">
		<header
			class="sticky top-0 z-50 w-full border-b border-[rgba(176,38,255,0.18)] bg-[rgba(61,56,51,0.85)] backdrop-blur-md"
		>
			<div class="flex justify-between items-center w-full px-6 md:px-8 py-4 max-w-[var(--container-max)] mx-auto">
				<a href="/" class="flex items-center gap-3 group">
					<!-- Pixel-block accent: 3×3 grid in purple/grey, echoes the
					     StripedGridMotion and reads as Indri's signature. -->
					<span class="block w-3 h-3 bg-primary-container shrink-0"></span>
					<span class="font-display text-xl md:text-2xl font-black uppercase tracking-[0.3em] text-on-surface group-hover:text-primary-container transition-colors">
						INDRI
					</span>
				</a>
			</div>
		</header>

		<main class="flex-1 w-full">
			<slot />
		</main>

		<footer class="w-full border-t border-[rgba(176,38,255,0.15)] bg-surface-container-lowest">
			<div
				class="max-w-[var(--container-max)] mx-auto px-6 md:px-8 py-10 md:py-12 flex flex-col md:flex-row md:items-end md:justify-between gap-6"
			>
				<div class="flex items-center gap-3">
					<span class="block w-3 h-3 bg-primary-container shrink-0"></span>
					<span class="font-display text-base font-black uppercase tracking-[0.3em] text-on-surface">
						INDRI
					</span>
				</div>
				<div class="font-display uppercase text-[10px] tracking-[0.3em] text-on-surface-variant">
					<span class="opacity-50">© {new Date().getFullYear()}</span>
				</div>
			</div>
		</footer>
	</body>
</html>
