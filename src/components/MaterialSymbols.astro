---
// Drop into Base's `head` slot on pages that actually render
// `material-symbols-outlined` glyphs. media="print" loads without blocking
// rendering (print media is never "current" on screen). The bundled script
// promotes it to media="all", which is idempotent — safe to run before or
// after the fetch completes, unlike a load-event listener which misses
// already-preloaded resources. <noscript> fallback keeps icons working when
// JS is disabled.
---
<link
	rel="stylesheet"
	media="print"
	data-promote
	href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
/>
<noscript>
	<link
		rel="stylesheet"
		href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
	/>
</noscript>
<script>
	// Switch each [data-promote] print stylesheet to media="all" so it
	// applies to the screen. Setting .media is idempotent — no race
	// condition whether the resource has already loaded or is still in-flight.
	//
	// Also wire astro:page-load: Astro deduplicates <script> tags across
	// ClientRouter navigations so this block only executes once, but the
	// <link media="print"> is re-injected into <head> on every swap. The
	// page-load listener re-promotes it on every subsequent navigation.
	const promote = () => {
		for (const link of document.querySelectorAll<HTMLLinkElement>('link[data-promote]')) {
			link.media = 'all';
		}
	};
	promote();
	document.addEventListener('astro:page-load', promote);
</script>
