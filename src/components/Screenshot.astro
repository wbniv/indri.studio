---
// AVIF/WebP-serving <picture> via Astro's native asset pipeline.
// `src` is an ImageMetadata resolved by the content collection's
// image() schema helper — Astro emits hashed _astro/* derivatives
// at build time and writes intrinsic width/height on the <img>
// fallback so layout is reserved before the image loads.
//
// widths is bounded to three sizes (phone / desktop / desktop-2x)
// to keep the variant count predictable; default Astro responsive
// widths would produce 6+ sizes × 2 formats per source.
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
	src: ImageMetadata;
	alt?: string;
	loading?: "lazy" | "eager";
	class?: string;
}

const { src, alt = "", loading = "lazy", class: className = "block w-full h-auto" } = Astro.props;
---

<Picture
	src={src}
	alt={alt}
	formats={["avif", "webp"]}
	widths={[480, 960, 1440]}
	sizes="(min-width: 768px) 50vw, 100vw"
	loading={loading}
	fetchpriority={loading === "eager" ? "high" : undefined}
	decoding="async"
	class={className}
/>
