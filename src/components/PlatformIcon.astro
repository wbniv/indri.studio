---
import MIcon from './MIcon.astro';

type Platform = "phone" | "tablet" | "console" | "tv" | "web";

interface Props {
	platform: Platform;
	class?: string;
}

const { platform, class: className = "" } = Astro.props;

const PLATFORMS: Record<Platform, { name: string; label: string }> = {
	phone:   { name: "mobile",         label: "Phone" },
	tablet:  { name: "tablet",         label: "Tablet" },
	console: { name: "sports_esports", label: "Console" },
	tv:      { name: "cast",           label: "TV" },
	web:     { name: "public",         label: "Web" },
};

const { name, label } = PLATFORMS[platform];
---

<MIcon name={name} class:list={["platform-icon", className]} label={label} size={40} />
