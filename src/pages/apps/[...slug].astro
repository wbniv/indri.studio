---
import AppLayout from "../../layouts/AppLayout.astro";
import StoreBadges from "../../components/StoreBadges.astro";
import Screenshot from "../../components/Screenshot.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import lightboxUrl from "../../scripts/cca-lightbox.js?url";

export async function getStaticPaths() {
	// Same sort as the homepage gallery — alphabetical with finding-your-way
	// pinned last — so prev/next here matches the order users see there.
	const posts = (await getCollection("apps", ({ data }) => !data.draft)).sort((a, b) => {
		if (a.id === "finding-your-way") return 1;
		if (b.id === "finding-your-way") return -1;
		return a.data.title.localeCompare(b.data.title);
	});
	return posts.map((post, i) => ({
		params: { slug: post.id },
		props: {
			post,
			// Wrap around at the edges so the catalogue cycles continuously.
			prev: posts[(i - 1 + posts.length) % posts.length],
			next: posts[(i + 1) % posts.length],
		},
	}));
}

interface Props {
	post: CollectionEntry<"apps">;
	prev: CollectionEntry<"apps">;
	next: CollectionEntry<"apps">;
}
const { post, prev, next } = Astro.props;
const { Content } = await render(post);

const now = new Date();
const upcoming = post.data.date.valueOf() > now.valueOf();

// OG image: first screenshot as an absolute URL. `src.src` is the hashed
// /_astro/*.{ext} path emitted by Astro's asset pipeline. Astro.site is
// set in astro.config.mjs (https://indri.studio).
const ogImage = post.data.screenshots[0]?.src.src
	? new URL(post.data.screenshots[0].src.src, Astro.site).href
	: undefined;
---

<AppLayout
	title={post.data.title}
	description={post.data.summary}
	ogImage={ogImage}
	ogType="article"
	theme={post.data.theme}
	prevHref={`/apps/${prev.id}/`}
	nextHref={`/apps/${next.id}/`}
>
	<article
		style="view-transition-name: app-content"
		class="max-w-[720px] mx-auto px-6 md:px-8 py-12 md:py-20"
	>
		<nav aria-label="Catalogue navigation" class="catalogue-nav">
			<a
				href={`/apps/${prev.id}/`}
				class="side-nav side-nav-inline group"
				aria-label={`Previous: ${prev.data.title}`}
			>
				<span class="material-symbols-outlined side-nav-arrow">chevron_left</span>
				<span class="side-nav-label">
					<span class="side-nav-eyebrow">previous</span>
					<span class="side-nav-title">{prev.data.title}</span>
				</span>
			</a>
			<a
				href="/#apps"
				class="side-nav-inline side-nav-all-apps"
				aria-label="All apps"
			>
				<span class="material-symbols-outlined side-nav-arrow" aria-hidden="true">apps</span>
				<span class="side-nav-title">All apps</span>
			</a>
			<a
				href={`/apps/${next.id}/`}
				class="side-nav side-nav-inline group"
				aria-label={`Next: ${next.data.title}`}
			>
				<span class="side-nav-label side-nav-label-right">
					<span class="side-nav-eyebrow">next</span>
					<span class="side-nav-title">{next.data.title}</span>
				</span>
				<span class="material-symbols-outlined side-nav-arrow">chevron_right</span>
			</a>
		</nav>

		<header class="mb-10">
			{upcoming && (
				<div class="flex flex-wrap items-center gap-3 mb-6">
					<span class="pill-purple">
						<span class="material-symbols-outlined text-sm">hourglass_top</span>
						Launching Soon
					</span>
				</div>
			)}

			<h1 class="font-display text-headline-lg text-primary-container tracking-tighter mb-6">
				{post.data.title}
			</h1>

			{post.data.summary && (
				<p class="font-body text-body-lg text-secondary border-l-2 border-primary-container pl-6">
					{post.data.summary}
				</p>
			)}

			<StoreBadges links={post.data.storeLinks} />
		</header>

		<div class="prose">
			<Content />
			{post.id === 'claude-code-authoring-formats' && <script src={lightboxUrl}></script>}
		</div>

		{post.data.screenshots.length > 0 && (
			<section class="mt-12 md:mt-16">
				<h2 class="section-label">screenshots</h2>
				<ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-6 list-none p-0 m-0">
					{post.data.screenshots.map((shot, idx) => (
						<li class="glass-card p-3">
							<Screenshot src={shot.src} alt={shot.alt ?? ""} loading={idx === 0 ? "eager" : "lazy"} />
							{shot.alt && (
								<p class="font-display uppercase tracking-[0.2em] text-[10px] text-on-surface-variant mt-3 mb-1 px-1">
									{shot.alt}
								</p>
							)}
						</li>
					))}
				</ul>
			</section>
		)}

	</article>

	<script>
		import { navigate } from 'astro:transitions/client';

		// Tag <html data-nav-dir="prev|next"> before a prev/next click so
		// the view-transition CSS picks the matching slide animation.
		// Re-applied at astro:before-preparation + astro:after-swap because
		// Astro's swap nukes <html> attributes mid-flight.
		let pendingDir = null;

		const setDir = (dir) => {
			pendingDir = dir;
			document.documentElement.dataset.navDir = dir;
		};

		document.addEventListener('astro:before-preparation', () => {
			// Re-assert the pending direction (Astro's swap nukes <html> attrs).
			// Also clear any stale direction from the *previous* navigation so a
			// rapid prev→next→prev sequence never applies the wrong slide.
			if (pendingDir) {
				document.documentElement.dataset.navDir = pendingDir;
			} else {
				delete document.documentElement.dataset.navDir;
			}
		});
		document.addEventListener('astro:after-swap', () => {
			if (pendingDir) document.documentElement.dataset.navDir = pendingDir;
		});
		document.addEventListener('astro:page-load', () => {
			pendingDir = null;
			delete document.documentElement.dataset.navDir;
		});

		// Delegated; capture phase so we set data-nav-dir before
		// ClientRouter's own click interceptor snapshots the old page.
		document.addEventListener('click', (e) => {
			const a = e.target && e.target.closest && e.target.closest('a[aria-label^="Previous:"], a[aria-label^="Next:"]');
			if (!a) return;
			setDir(a.getAttribute('aria-label').startsWith('Previous') ? 'prev' : 'next');
		}, true);

		// Touch swipe: horizontal pan ≥ 60px on the article navigates to
		// prev (swipe right) or next (swipe left). Ignores vertical
		// scrolls so the page can still scroll normally. Touches starting
		// within EDGE_GUARD of either viewport edge are skipped so the
		// iOS Safari back/forward edge gesture isn't fighting us.
		const SWIPE_MIN = 60;
		const SWIPE_MAX_OFF_AXIS = 40;
		const EDGE_GUARD = 24;
		let touchStart = null;

		document.addEventListener('touchstart', (e) => {
			if (e.touches.length !== 1) return;
			const article = e.target && e.target.closest && e.target.closest('article');
			if (!article) return;
			const t = e.touches[0];
			if (t.clientX < EDGE_GUARD || t.clientX > window.innerWidth - EDGE_GUARD) return;
			touchStart = { x: t.clientX, y: t.clientY };
		}, { passive: true });

		document.addEventListener('touchend', (e) => {
			if (!touchStart) return;
			const t = e.changedTouches[0];
			const dx = t.clientX - touchStart.x;
			const dy = t.clientY - touchStart.y;
			touchStart = null;
			if (Math.abs(dy) > SWIPE_MAX_OFF_AXIS) return;
			if (Math.abs(dx) < SWIPE_MIN) return;
			const dir = dx > 0 ? 'prev' : 'next';
			const label = dir === 'prev' ? 'Previous' : 'Next';
			const a = document.querySelector(`a[aria-label^="${label}:"]`);
			const href = a && a.getAttribute('href');
			if (!href) return;
			setDir(dir);
			navigate(href);
		}, { passive: true });
	</script>

	<style>
		.prose :global(h2) {
			font-family: var(--font-display);
			font-size: 24px;
			line-height: 1.3;
			font-weight: 600;
			letter-spacing: -0.01em;
			color: var(--color-on-surface);
			margin: 2.25rem 0 1rem;
			text-transform: uppercase;
		}
		.prose :global(h3) {
			font-family: var(--font-display);
			font-size: 18px;
			line-height: 1.4;
			font-weight: 600;
			color: var(--color-on-surface);
			margin: 2rem 0 0.75rem;
		}
		.prose :global(p) {
			font-family: var(--font-body);
			font-size: 16px;
			line-height: 1.7;
			color: var(--color-secondary);
			margin: 0 0 1.25em;
		}
		.prose :global(a) {
			color: var(--color-primary-container);
			text-decoration-color: color-mix(in srgb, var(--color-primary-container) 30%, transparent);
			text-decoration-line: underline;
			text-underline-offset: 3px;
			transition: color 150ms ease, text-decoration-color 150ms ease;
		}
		.prose :global(a:hover) {
			text-decoration-color: var(--color-primary-container);
		}
		.prose :global(a[data-external])::after {
			content: "";
			display: inline-block;
			width: 0.7em;
			height: 0.7em;
			margin-left: 0.18em;
			vertical-align: 0.05em;
			background-color: currentColor;
			-webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M7 17 17 7'/><path d='M8 7h9v9'/></svg>") no-repeat center / contain;
			mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M7 17 17 7'/><path d='M8 7h9v9'/></svg>") no-repeat center / contain;
			opacity: 0.75;
		}
		.prose :global(ul),
		.prose :global(ol) {
			font-family: var(--font-body);
			color: var(--color-secondary);
			margin: 0 0 1.25em;
			padding-left: 1.5rem;
		}
		.prose :global(li) {
			margin: 0.35em 0;
			line-height: 1.65;
		}
		.prose :global(li::marker) {
			color: var(--color-primary-container);
		}
		.prose :global(blockquote) {
			border-left: 2px solid var(--color-primary-container);
			padding-left: 1.25rem;
			margin: 1.5em 0;
			color: var(--color-on-surface-variant);
			font-style: italic;
		}
		.prose :global(code) {
			font-family: var(--font-mono);
			font-size: 0.9em;
			background: var(--color-surface-container);
			border: 1px solid color-mix(in srgb, var(--color-primary-container) 10%, transparent);
			padding: 0.15em 0.4em;
			border-radius: var(--radius-DEFAULT);
			color: var(--color-primary-fixed);
		}
		.prose :global(pre) {
			background: var(--color-surface-container-low);
			border: 1px solid color-mix(in srgb, var(--color-primary-container) 15%, transparent);
			padding: 1rem 1.25rem;
			overflow-x: auto;
			margin: 1.5em 0;
			border-radius: var(--radius-DEFAULT);
		}
		.prose :global(pre code) {
			background: transparent;
			border: none;
			padding: 0;
			color: var(--color-on-surface);
		}
		.prose :global(hr) {
			border: 0;
			border-top: 1px solid var(--color-outline-variant);
			margin: 2.5em 0;
		}
		.prose :global(img) {
			max-width: 100%;
			height: auto;
			border: 1px solid var(--color-outline-variant);
			margin: 1.5em 0;
		}
		.prose :global(strong) {
			color: var(--color-on-surface);
			font-weight: 600;
		}

		.catalogue-nav {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 0.5rem;
			margin-bottom: 2.5rem;
		}
		.side-nav-inline {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			padding: 0.5rem 0.75rem;
			background: rgba(61, 56, 51, 0.55);
			border: 1px solid rgba(255, 255, 255, 0.06);
			border-radius: 12px;
			color: var(--color-on-surface-variant);
			backdrop-filter: blur(6px);
			transition: background 180ms ease, color 180ms ease, padding 180ms ease,
				border-color 180ms ease;
			text-decoration: none;
		}
		.side-nav-inline:hover {
			background: color-mix(in srgb, var(--color-primary-container) 18%, transparent);
			border-color: color-mix(in srgb, var(--color-primary-container) 45%, transparent);
			color: var(--color-on-surface);
			padding: 0.5rem 1rem;
		}
		.side-nav-arrow {
			font-size: 28px !important;
			line-height: 1;
			color: var(--color-primary-container);
		}
		.side-nav-all-apps .side-nav-title {
			display: inline-flex;
			max-width: none;
			opacity: 1;
		}
		.side-nav-label {
			display: none;
			flex-direction: column;
			line-height: 1.1;
			max-width: 0;
			overflow: hidden;
			white-space: nowrap;
			opacity: 0;
			transition: max-width 220ms ease, opacity 220ms ease 60ms;
		}
		.side-nav-label-right {
			text-align: right;
		}
		.side-nav-inline:hover .side-nav-label {
			max-width: 220px;
			opacity: 1;
		}
		.side-nav-eyebrow {
			font-family: var(--font-display);
			text-transform: uppercase;
			letter-spacing: 0.25em;
			font-size: 9px;
			color: var(--color-on-surface-variant);
			margin-bottom: 2px;
		}
		.side-nav-title {
			font-family: var(--font-display);
			text-transform: uppercase;
			letter-spacing: -0.01em;
			font-weight: 800;
			font-size: 14px;
			color: var(--color-on-surface);
		}

		@media (min-width: 768px) {
			.side-nav-label {
				display: flex;
			}
		}

		@media (max-width: 480px) {
			.side-nav-inline {
				padding: 0.35rem 0.55rem;
			}
			.side-nav-inline:hover {
				padding: 0.35rem 0.7rem;
			}
			.side-nav-arrow {
				font-size: 24px !important;
			}
		}
	</style>

	<style is:global>
		/* View transitions between app pages. Direction comes from
		   <html data-nav-dir="prev|next"> set by the prev/next click
		   handler before navigation. Slide is scoped to the article
		   (transition:name="app-content"); the persistent header/footer
		   sit still while the article slides under them. The root pair
		   has its animation suppressed so the rest of the page snaps
		   instead of crossfading. */
		::view-transition-old(root),
		::view-transition-new(root) {
			animation: none;
		}

		@media (prefers-reduced-motion: no-preference) {
			/* Two parallel animations per pseudo-element: translate
			   keeps its asymmetric easing (outgoing accelerates,
			   incoming decelerates), but opacity fades on linear
			   timing so the cross-fade is actually visible across the
			   whole transition instead of getting back-loaded into a
			   sudden disappear at the end. */
			:root[data-nav-dir="next"]::view-transition-old(app-content) {
				animation:
					app-slide-out-left 280ms cubic-bezier(0.4, 0, 1, 1) both,
					app-fade-out      160ms cubic-bezier(0.4, 0, 0.2, 1) both;
			}
			:root[data-nav-dir="next"]::view-transition-new(app-content) {
				animation:
					app-slide-in-right 280ms cubic-bezier(0, 0, 0.2, 1) both,
					app-fade-in        280ms linear both;
			}
			:root[data-nav-dir="prev"]::view-transition-old(app-content) {
				animation:
					app-slide-out-right 280ms cubic-bezier(0.4, 0, 1, 1) both,
					app-fade-out        160ms cubic-bezier(0.4, 0, 0.2, 1) both;
			}
			:root[data-nav-dir="prev"]::view-transition-new(app-content) {
				animation:
					app-slide-in-left 280ms cubic-bezier(0, 0, 0.2, 1) both,
					app-fade-in       280ms linear both;
			}
		}

		@keyframes app-slide-out-left  { from { transform: translateX(0);    } to { transform: translateX(-100%); } }
		@keyframes app-slide-in-right  { from { transform: translateX(100%); } to { transform: translateX(0);     } }
		@keyframes app-slide-out-right { from { transform: translateX(0);    } to { transform: translateX(100%);  } }
		@keyframes app-slide-in-left   { from { transform: translateX(-100%);} to { transform: translateX(0);     } }
		@keyframes app-fade-out        { from { opacity: 1; } to { opacity: 0; } }
		@keyframes app-fade-in         { from { opacity: 0; } to { opacity: 1; } }
	</style>
</AppLayout>
