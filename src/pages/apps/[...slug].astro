---
import AppLayout from "../../layouts/AppLayout.astro";
import StoreBadges from "../../components/StoreBadges.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
	// Same sort as the homepage gallery — alphabetical with finding-your-way
	// pinned last — so prev/next here matches the order users see there.
	const posts = (await getCollection("apps", ({ data }) => !data.draft)).sort((a, b) => {
		if (a.id === "finding-your-way") return 1;
		if (b.id === "finding-your-way") return -1;
		return a.data.title.localeCompare(b.data.title);
	});
	return posts.map((post, i) => ({
		params: { slug: post.id },
		props: {
			post,
			// Wrap around at the edges so the catalogue cycles continuously.
			prev: posts[(i - 1 + posts.length) % posts.length],
			next: posts[(i + 1) % posts.length],
		},
	}));
}

interface Props {
	post: CollectionEntry<"apps">;
	prev: CollectionEntry<"apps">;
	next: CollectionEntry<"apps">;
}
const { post, prev, next } = Astro.props;
const { Content } = await render(post);

const now = new Date();
const upcoming = post.data.date.valueOf() > now.valueOf();
const fmtDate = (d: Date) => d.toISOString().slice(0, 10);
---

<AppLayout title={post.data.title} description={post.data.summary} theme={post.data.theme}>
	<article class="max-w-[720px] mx-auto px-6 md:px-8 py-12 md:py-20">
		<a
			href="/#apps"
			class="inline-flex items-center font-display text-label-md uppercase tracking-[0.2em] text-outline hover:text-primary-container transition-colors mb-10"
		>
			<span class="material-symbols-outlined text-base mr-1">chevron_left</span>
			All apps
		</a>

		<header class="mb-10">
			{upcoming && (
				<div class="flex flex-wrap items-center gap-3 mb-6">
					<span class="pill-purple">
						<span class="material-symbols-outlined text-sm">hourglass_top</span>
						Launching Soon
					</span>
				</div>
			)}

			<h1 class="font-display text-headline-lg text-primary-container tracking-tighter mb-6">
				{post.data.title}
			</h1>

			{post.data.summary && (
				<p class="font-body text-body-lg text-secondary border-l-2 border-primary-container pl-6">
					{post.data.summary}
				</p>
			)}

			<StoreBadges links={post.data.storeLinks} />
		</header>

		<div class="prose">
			<Content />
		</div>

		{post.data.screenshots.length > 0 && (
			<section class="mt-12 md:mt-16">
				<h2 class="section-label">screenshots</h2>
				<ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-6 list-none p-0 m-0">
					{post.data.screenshots.map((shot) => (
						<li class="glass-card p-3">
							<img
								src={shot.src}
								alt={shot.alt ?? ""}
								loading="lazy"
								class="block w-full h-auto"
							/>
							{shot.alt && (
								<p class="font-display uppercase tracking-[0.2em] text-[10px] text-on-surface-variant mt-3 mb-1 px-1">
									{shot.alt}
								</p>
							)}
						</li>
					))}
				</ul>
			</section>
		)}

	</article>

	<nav aria-label="Catalogue navigation">
		<a
			href={`/apps/${prev.id}/`}
			class="side-nav side-nav-prev group"
			aria-label={`Previous: ${prev.data.title}`}
		>
			<span class="material-symbols-outlined side-nav-arrow">chevron_left</span>
			<span class="side-nav-label">
				<span class="side-nav-eyebrow">previous</span>
				<span class="side-nav-title">{prev.data.title}</span>
			</span>
		</a>
		<a
			href={`/apps/${next.id}/`}
			class="side-nav side-nav-next group"
			aria-label={`Next: ${next.data.title}`}
		>
			<span class="side-nav-label side-nav-label-right">
				<span class="side-nav-eyebrow">next</span>
				<span class="side-nav-title">{next.data.title}</span>
			</span>
			<span class="material-symbols-outlined side-nav-arrow">chevron_right</span>
		</a>
	</nav>

	<script define:vars={{ prevHref: `/apps/${prev.id}/`, nextHref: `/apps/${next.id}/` }}>
		// Keyboard navigation between apps. Defers to any open <dialog>
		// (e.g. an in-page lightbox) so its own arrow handler can take
		// the keys. Also skips when focus is in an editable field.
		document.addEventListener('keydown', (e) => {
			if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
			if (e.ctrlKey || e.metaKey || e.altKey) return;
			if (document.querySelector('dialog[open]')) return;
			const t = e.target;
			if (t && (t.isContentEditable || /^(INPUT|TEXTAREA|SELECT)$/.test(t.tagName))) return;
			e.preventDefault();
			window.location.assign(e.key === 'ArrowLeft' ? prevHref : nextHref);
		});
	</script>

	<style>
		.prose :global(h2) {
			font-family: var(--font-display);
			font-size: 24px;
			line-height: 1.3;
			font-weight: 600;
			letter-spacing: -0.01em;
			color: var(--color-on-surface);
			margin: 2.25rem 0 1rem;
			text-transform: uppercase;
		}
		.prose :global(h3) {
			font-family: var(--font-display);
			font-size: 18px;
			line-height: 1.4;
			font-weight: 600;
			color: var(--color-on-surface);
			margin: 2rem 0 0.75rem;
		}
		.prose :global(p) {
			font-family: var(--font-body);
			font-size: 16px;
			line-height: 1.7;
			color: var(--color-secondary);
			margin: 0 0 1.25em;
		}
		.prose :global(a) {
			color: var(--color-primary-container);
			text-decoration-color: color-mix(in srgb, var(--color-primary-container) 30%, transparent);
			text-decoration-line: underline;
			text-underline-offset: 3px;
			transition: color 150ms ease, text-decoration-color 150ms ease;
		}
		.prose :global(a:hover) {
			text-decoration-color: var(--color-primary-container);
		}
		.prose :global(ul),
		.prose :global(ol) {
			font-family: var(--font-body);
			color: var(--color-secondary);
			margin: 0 0 1.25em;
			padding-left: 1.5rem;
		}
		.prose :global(li) {
			margin: 0.35em 0;
			line-height: 1.65;
		}
		.prose :global(li::marker) {
			color: var(--color-primary-container);
		}
		.prose :global(blockquote) {
			border-left: 2px solid var(--color-primary-container);
			padding-left: 1.25rem;
			margin: 1.5em 0;
			color: var(--color-on-surface-variant);
			font-style: italic;
		}
		.prose :global(code) {
			font-family: var(--font-mono);
			font-size: 0.9em;
			background: var(--color-surface-container);
			border: 1px solid color-mix(in srgb, var(--color-primary-container) 10%, transparent);
			padding: 0.15em 0.4em;
			border-radius: var(--radius-DEFAULT);
			color: var(--color-primary-fixed);
		}
		.prose :global(pre) {
			background: var(--color-surface-container-low);
			border: 1px solid color-mix(in srgb, var(--color-primary-container) 15%, transparent);
			padding: 1rem 1.25rem;
			overflow-x: auto;
			margin: 1.5em 0;
			border-radius: var(--radius-DEFAULT);
		}
		.prose :global(pre code) {
			background: transparent;
			border: none;
			padding: 0;
			color: var(--color-on-surface);
		}
		.prose :global(hr) {
			border: 0;
			border-top: 1px solid var(--color-outline-variant);
			margin: 2.5em 0;
		}
		.prose :global(img) {
			max-width: 100%;
			height: auto;
			border: 1px solid var(--color-outline-variant);
			margin: 1.5em 0;
		}
		.prose :global(strong) {
			color: var(--color-on-surface);
			font-weight: 600;
		}

		/* Fixed-position prev/next arrows on the sides of the content.
		   Visible on screens wide enough for the gutter; on narrower
		   viewports they shrink and ride the edges. */
		.side-nav {
			position: fixed;
			top: 50%;
			transform: translateY(-50%);
			display: flex;
			align-items: center;
			gap: 0.5rem;
			padding: 1.5rem 0.875rem;
			min-height: 120px;
			background: rgba(61, 56, 51, 0.55);
			border: 1px solid rgba(255, 255, 255, 0.06);
			border-radius: 12px;
			color: var(--color-on-surface-variant);
			backdrop-filter: blur(6px);
			transition: background 180ms ease, color 180ms ease, padding 180ms ease,
				border-color 180ms ease, transform 180ms ease;
			z-index: 30;
			text-decoration: none;
		}
		.side-nav:hover {
			background: color-mix(in srgb, var(--color-primary-container) 18%, transparent);
			border-color: color-mix(in srgb, var(--color-primary-container) 45%, transparent);
			color: var(--color-on-surface);
			padding: 1.5rem 1.25rem;
		}
		.side-nav-prev {
			left: max(0.75rem, calc((100vw - 720px) / 2 - 96px));
		}
		.side-nav-next {
			right: max(0.75rem, calc((100vw - 720px) / 2 - 96px));
		}
		.side-nav-arrow {
			font-size: 44px !important;
			line-height: 1;
			color: var(--color-primary-container);
		}
		.side-nav-label {
			display: none;
			flex-direction: column;
			line-height: 1.1;
			max-width: 0;
			overflow: hidden;
			white-space: nowrap;
			opacity: 0;
			transition: max-width 220ms ease, opacity 220ms ease 60ms;
		}
		.side-nav-label-right {
			text-align: right;
		}
		.side-nav:hover .side-nav-label {
			max-width: 220px;
			opacity: 1;
		}
		.side-nav-eyebrow {
			font-family: var(--font-display);
			text-transform: uppercase;
			letter-spacing: 0.25em;
			font-size: 9px;
			color: var(--color-on-surface-variant);
			margin-bottom: 2px;
		}
		.side-nav-title {
			font-family: var(--font-display);
			text-transform: uppercase;
			letter-spacing: -0.01em;
			font-weight: 800;
			font-size: 14px;
			color: var(--color-on-surface);
		}

		@media (min-width: 1024px) {
			.side-nav-label {
				display: flex;
			}
		}

		/* On very narrow screens, shrink the buttons so they don't crowd
		   the body text. */
		@media (max-width: 480px) {
			.side-nav {
				padding: 1rem 0.5rem;
				min-height: 88px;
				border-radius: 10px;
			}
			.side-nav-arrow {
				font-size: 32px !important;
			}
		}
	</style>
</AppLayout>
