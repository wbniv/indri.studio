---
import AppLayout from "../../layouts/AppLayout.astro";
import MIcon from "../../components/MIcon.astro";
import { getCollection, getEntry, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
	const all = await getCollection("docs");
	return all.map((doc) => ({
		params: { slug: doc.id },
		props: { doc },
	}));
}

interface Props {
	doc: CollectionEntry<"docs">;
}
const { doc } = Astro.props;
const { Content } = await render(doc);

// Link back to the owning product page (if it exists / isn't a draft).
const app = await getEntry("apps", doc.data.app);
const appTitle = app?.data.title ?? "the project";

// Downloadable source + PDF live under public/docs/<slug>.{md,pdf}.
const mdHref = `/docs/${doc.id}.md`;
const pdfHref = `/docs/${doc.id}.pdf`;
---

<AppLayout title={doc.data.title} description={doc.data.summary}>
	<article class="max-w-[760px] mx-auto px-6 md:px-8 py-12 md:py-20">
		<nav class="mb-10">
			<a href={`/apps/${doc.data.app}/`} class="back-link">
				<MIcon name="chevron_left" size={20} ariaHidden />
				<span>{appTitle}</span>
			</a>
		</nav>

		<header class="mb-8">
			<h1 class="font-display text-headline-lg text-primary-container tracking-tighter mb-5">
				{doc.data.title}
			</h1>
			{doc.data.summary && (
				<p class="font-body text-body-lg text-secondary border-l-2 border-primary-container pl-6 mb-6">
					{doc.data.summary}
				</p>
			)}
			<div class="doc-downloads">
				<a href={mdHref} download class="doc-dl"><MIcon name="description" size={16} ariaHidden /> Markdown</a>
				<a href={pdfHref} download class="doc-dl"><MIcon name="picture_as_pdf" size={16} ariaHidden /> PDF</a>
			</div>
		</header>

		<div class="prose">
			<Content />
		</div>

		{doc.data.sourceCommit && (
			<footer class="doc-provenance">
				Snapshot from <code>{doc.data.sourceRepo ?? "llvm-mos-65816"}</code>
				@ <code>{doc.data.sourceCommit}</code>. Apache-2.0 with LLVM exceptions.
			</footer>
		)}
	</article>

	<style>
		.back-link {
			display: inline-flex;
			align-items: center;
			gap: 0.4rem;
			font-family: var(--font-display);
			text-transform: uppercase;
			letter-spacing: 0.08em;
			font-size: 12px;
			font-weight: 700;
			color: var(--color-on-surface-variant);
			text-decoration: none;
			transition: color 150ms ease;
		}
		.back-link:hover { color: var(--color-primary-container); }
		.back-link :global(svg) { color: var(--color-primary-container); }

		.doc-downloads { display: flex; flex-wrap: wrap; gap: 0.75rem; }
		.doc-dl {
			display: inline-flex;
			align-items: center;
			gap: 0.4rem;
			padding: 0.4rem 0.85rem;
			border: 1px solid color-mix(in srgb, var(--color-primary-container) 35%, transparent);
			border-radius: 10px;
			font-family: var(--font-display);
			text-transform: uppercase;
			letter-spacing: 0.06em;
			font-size: 11px;
			font-weight: 700;
			color: var(--color-on-surface);
			text-decoration: none;
			transition: background 160ms ease, border-color 160ms ease;
		}
		.doc-dl:hover {
			background: color-mix(in srgb, var(--color-primary-container) 14%, transparent);
			border-color: var(--color-primary-container);
		}
		.doc-dl :global(svg) { color: var(--color-primary-container); }

		.doc-provenance {
			margin-top: 3rem;
			padding-top: 1.25rem;
			border-top: 1px solid var(--color-outline-variant);
			font-family: var(--font-body);
			font-size: 13px;
			color: var(--color-on-surface-variant);
		}
		.doc-provenance :global(code) {
			font-family: var(--font-mono);
			font-size: 0.92em;
			color: var(--color-primary-fixed);
		}

		/* Prose styles — shared with the app pages (src/pages/apps/[...slug].astro).
		   Kept in sync by hand; both render markdown into <div class="prose">. */
		.prose :global(h2) {
			font-family: var(--font-display);
			font-size: 24px;
			line-height: 1.3;
			font-weight: 600;
			letter-spacing: -0.01em;
			color: var(--color-on-surface);
			margin: 2.25rem 0 1rem;
			text-transform: uppercase;
		}
		.prose :global(h3) {
			font-family: var(--font-display);
			font-size: 18px;
			line-height: 1.4;
			font-weight: 600;
			color: var(--color-on-surface);
			margin: 2rem 0 0.75rem;
		}
		.prose :global(h4) {
			font-family: var(--font-display);
			font-size: 15px;
			font-weight: 600;
			color: var(--color-on-surface-variant);
			margin: 1.5rem 0 0.6rem;
			text-transform: uppercase;
			letter-spacing: 0.04em;
		}
		.prose :global(p) {
			font-family: var(--font-body);
			font-size: 16px;
			line-height: 1.7;
			color: var(--color-secondary);
			margin: 0 0 1.25em;
		}
		.prose :global(a) {
			color: var(--color-primary-container);
			text-decoration-color: color-mix(in srgb, var(--color-primary-container) 30%, transparent);
			text-decoration-line: underline;
			text-underline-offset: 3px;
			transition: color 150ms ease, text-decoration-color 150ms ease;
		}
		.prose :global(a:hover) { text-decoration-color: var(--color-primary-container); }
		.prose :global(a[data-external])::after {
			content: "";
			display: inline-block;
			width: 0.7em;
			height: 0.7em;
			margin-left: 0.18em;
			vertical-align: 0.05em;
			background-color: currentColor;
			-webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M7 17 17 7'/><path d='M8 7h9v9'/></svg>") no-repeat center / contain;
			mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M7 17 17 7'/><path d='M8 7h9v9'/></svg>") no-repeat center / contain;
			opacity: 0.75;
		}
		.prose :global(ul),
		.prose :global(ol) {
			font-family: var(--font-body);
			color: var(--color-secondary);
			margin: 0 0 1.25em;
			padding-left: 1.5rem;
		}
		.prose :global(li) { margin: 0.35em 0; line-height: 1.65; }
		.prose :global(li::marker) { color: var(--color-primary-container); }
		.prose :global(blockquote) {
			border-left: 2px solid var(--color-primary-container);
			padding-left: 1.25rem;
			margin: 1.5em 0;
			color: var(--color-on-surface-variant);
			font-style: italic;
		}
		.prose :global(code) {
			font-family: var(--font-mono);
			font-size: 0.9em;
			background: var(--color-surface-container);
			border: 1px solid color-mix(in srgb, var(--color-primary-container) 10%, transparent);
			padding: 0.15em 0.4em;
			border-radius: var(--radius-DEFAULT);
			color: var(--color-primary-fixed);
		}
		.prose :global(pre) {
			background: var(--color-surface-container-low);
			border: 1px solid color-mix(in srgb, var(--color-primary-container) 15%, transparent);
			padding: 1rem 1.25rem;
			overflow-x: auto;
			margin: 1.5em 0;
			border-radius: var(--radius-DEFAULT);
		}
		/* Let Shiki's inline token colours show through (scoped so we don't clobber
		   the .astro-code spans the markdown pipeline emits). */
		.prose :global(pre:not(.astro-code) code) {
			background: transparent;
			border: none;
			padding: 0;
			color: var(--color-on-surface);
		}
		.prose :global(pre.astro-code code) {
			background: transparent;
			border: none;
			padding: 0;
		}
		.prose :global(table) {
			width: 100%;
			border-collapse: collapse;
			margin: 1.5em 0;
			font-family: var(--font-body);
			font-size: 14px;
		}
		.prose :global(th),
		.prose :global(td) {
			border: 1px solid var(--color-outline-variant);
			padding: 0.5em 0.75em;
			text-align: left;
			color: var(--color-secondary);
		}
		.prose :global(th) {
			font-family: var(--font-display);
			text-transform: uppercase;
			letter-spacing: 0.04em;
			font-size: 11px;
			color: var(--color-on-surface);
			background: color-mix(in srgb, var(--color-primary-container) 8%, transparent);
		}
		.prose :global(hr) {
			border: 0;
			border-top: 1px solid var(--color-outline-variant);
			margin: 2.5em 0;
		}
		.prose :global(img) {
			max-width: 100%;
			height: auto;
			border: 1px solid var(--color-outline-variant);
			margin: 1.5em 0;
		}
		.prose :global(strong) { color: var(--color-on-surface); font-weight: 600; }
	</style>
</AppLayout>
