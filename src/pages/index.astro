---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const allApps = (await getCollection("apps", ({ data }) => !data.draft))
	.sort((a, b) => {
		// Finding Your Way is a commissioned piece (a port for an external author),
		// not an Indri-originated product. Pin it last in the catalogue.
		if (a.id === "finding-your-way") return 1;
		if (b.id === "finding-your-way") return -1;
		return a.data.title.localeCompare(b.data.title);
	});

const team = (await getCollection("team")).sort(
	(a, b) => a.data.order - b.data.order,
);
---

<Base title="indri">
	<!-- Hero -->
	<section class="relative overflow-hidden min-h-[640px] md:min-h-[760px] flex items-center">
		<div class="relative z-10 w-full max-w-[var(--container-max)] mx-auto px-6 md:px-8 lg:px-[var(--spacing-margin)] py-24 md:py-32">
			<div class="max-w-3xl">
				<h1 class="font-display mb-2">
					<span class="block text-6xl sm:text-7xl md:text-8xl lg:text-[120px] leading-[0.9] tracking-tight font-black uppercase text-primary-container">
						Software
					</span>
					<span class="block text-3xl sm:text-4xl md:text-5xl leading-[1] tracking-tight font-light text-on-surface mt-2">
						for everyone.
					</span>
				</h1>

				<p class="font-body text-body-lg text-on-surface-variant max-w-xl mt-10 border-l-2 border-primary-container pl-6">
					We build apps people use every day — coloring, bookkeeping, parking, play.
				</p>
			</div>
		</div>
	</section>

	<!-- Our apps -->
	<section id="apps" class="max-w-[var(--container-max)] mx-auto px-6 md:px-8 lg:px-[var(--spacing-margin)] py-16 md:py-24 scroll-mt-20">
		<h2 class="section-label">our apps</h2>

		<ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
			{allApps.map((app, idx) => {
				// Real screenshots first, with thematic stand-ins as fallback
				// for apps that don't have any captures yet. Stand-ins are
				// rendered far more subdued (grayscale, lower opacity) since
				// they're decorative, not representative of actual UI.
				const usingPlaceholder = app.data.screenshots.length === 0;
				const shots = usingPlaceholder ? app.data.cardImages : app.data.screenshots;
				const primaryClass = usingPlaceholder
					? "absolute inset-0 w-full h-full object-cover opacity-20 grayscale contrast-75"
					: "absolute inset-0 w-full h-full object-cover opacity-35 saturate-50";
				const secondaryClass = usingPlaceholder
					? "absolute -bottom-[20%] -right-[15%] w-3/4 h-3/4 object-cover opacity-15 grayscale contrast-75 mix-blend-luminosity"
					: "absolute -bottom-[20%] -right-[15%] w-3/4 h-3/4 object-cover opacity-25 saturate-50 mix-blend-luminosity";
				// Per-card visual variation: slight differences in rotation and
				// scale across the grid so cards don't read as a uniform stripe.
				// Alternates direction; magnitude derived from index.
				const rotation = (idx % 2 === 0 ? 1 : -1) * (5 + ((idx * 3) % 7));
				const scale = 1.25 + ((idx % 3) * 0.05);
				return (
					<li>
						<a
							href={`/apps/${app.id}/`}
							class="glass-card glass-card-hover relative overflow-hidden block h-full p-6 md:p-8 group"
						>
							{shots.length > 0 && (
								<div class="absolute inset-0 z-0 pointer-events-none" aria-hidden="true">
									<img
										src={shots[0].src}
										alt=""
										loading="lazy"
										class={primaryClass}
										style={`transform: scale(${scale}) rotate(${rotation}deg);`}
									/>
									{shots[1] && (
										<img
											src={shots[1].src}
											alt=""
											loading="lazy"
											class={secondaryClass}
											style={`transform: rotate(${-rotation * 1.4}deg);`}
										/>
									)}
									{/* Darken overlay — keeps text legible regardless of underlying screenshot */}
									<div class="absolute inset-0 bg-gradient-to-br from-[rgba(74,70,65,0.82)] via-[rgba(74,70,65,0.58)] to-[rgba(74,70,65,0.40)]"></div>
								</div>
							)}

							<div class="relative z-10">
								<div class="mb-8">
									<span class="block w-9 h-9 bg-[rgba(176,38,255,0.12)] border border-[rgba(176,38,255,0.4)]"></span>
								</div>
								<h3 class="app-card-title font-display text-2xl md:text-[28px] font-black text-on-surface mb-3 uppercase tracking-tight leading-[1.05]">
									{app.data.title}
								</h3>
								{app.data.summary && (
									<p class="font-body text-body-md text-on-surface-variant">
										{app.data.summary}
									</p>
								)}
								{app.data.b2b && (
									<p class="font-body text-sm text-on-surface-variant/75 mt-3 border-l-2 border-primary-container/60 pl-3">
										{app.data.b2b}
									</p>
								)}
							</div>
						</a>
					</li>
				);
			})}
		</ul>
	</section>

	<!-- About indri -->
	<section id="about" class="max-w-[var(--container-max)] mx-auto px-6 md:px-8 lg:px-[var(--spacing-margin)] py-16 md:py-24 scroll-mt-20">
		<h2 class="section-label">about indri</h2>

		<p class="font-display text-3xl md:text-4xl lg:text-5xl font-black uppercase leading-[1.1] tracking-tight text-on-surface max-w-4xl">
			<span class="text-primary-container">Indri</span> is a small studio.<br/>
			If it should exist and we'd use it,<br/>
			we build it.
		</p>
	</section>

	<!-- The team -->
	<section id="team" class="max-w-[var(--container-max)] mx-auto px-6 md:px-8 lg:px-[var(--spacing-margin)] py-16 md:py-24 scroll-mt-20">
		<h2 class="section-label">the team</h2>

		<ul class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
			{team.map((member) => (
				<li class="glass-card p-5 md:p-6">
					<h3 class="font-display text-xl md:text-2xl font-black text-on-surface mb-1 uppercase tracking-tight">
						{member.data.name}
					</h3>
					<p class="font-display uppercase tracking-[0.2em] text-[10px] text-primary-container mb-4">
						{member.data.role}
					</p>
					<p class="font-body text-sm text-on-surface-variant">
						{member.data.bio}
					</p>
				</li>
			))}
		</ul>
	</section>

</Base>
